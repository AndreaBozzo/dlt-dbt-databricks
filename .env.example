# Copy to `.env` and fill in real values. `.env` is gitignored.
# Load it into your shell before running examples:
#   - uv run automatically picks up .env via python-dotenv in the scripts, OR
#   - export manually:  set -a; source .env; set +a   (bash)
#
# ─────────────────────────────────────────────────────────────────────────────
# Databricks workspace (shared by dlt and dbt)
# ─────────────────────────────────────────────────────────────────────────────
# Workspace hostname WITHOUT https://   e.g. dbc-a1b2c3d4-e5f6.cloud.databricks.com
DATABRICKS_HOST=
# SQL warehouse HTTP path. Find under: SQL Warehouses > <your warehouse> > Connection details
#   e.g. /sql/1.0/warehouses/abcd1234efgh5678
DATABRICKS_HTTP_PATH=
# Personal access token (User Settings > Developer > Access tokens).
# For production prefer OAuth M2M (see docs/setup-databricks.md).
DATABRICKS_TOKEN=
# Unity Catalog catalog + the schema dbt builds models into.
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=analytics

# ─────────────────────────────────────────────────────────────────────────────
# dlt destination credentials
# dlt reads env vars in the form DESTINATION__DATABRICKS__CREDENTIALS__<FIELD>.
# These intentionally mirror the values above so you only set them once.
# (Alternatively put them in ingestion/.dlt/secrets.toml — see that file.)
# ─────────────────────────────────────────────────────────────────────────────
DESTINATION__DATABRICKS__CREDENTIALS__SERVER_HOSTNAME=${DATABRICKS_HOST}
DESTINATION__DATABRICKS__CREDENTIALS__HTTP_PATH=${DATABRICKS_HTTP_PATH}
DESTINATION__DATABRICKS__CREDENTIALS__ACCESS_TOKEN=${DATABRICKS_TOKEN}
DESTINATION__DATABRICKS__CREDENTIALS__CATALOG=${DATABRICKS_CATALOG}
# The Unity Catalog schema dlt LOADS INTO (the dbt sources read from here).
DLT_DATASET_NAME=raw

# ─────────────────────────────────────────────────────────────────────────────
# SQL source for sql_database_to_databricks.py
# Default = EBI's PUBLIC read-only RNAcentral Postgres (real hosted DB, safe to share).
# Security scanners may flag this because it is password-shaped; see SECURITY.md for context.
# Swap for your own operational DB connection string.
# ─────────────────────────────────────────────────────────────────────────────
SOURCES__SQL_DATABASE__CREDENTIALS=postgresql://reader:NWDMCE5xdipIjRrp@hh-pgsql-public.ebi.ac.uk:5432/pfmegrnargs

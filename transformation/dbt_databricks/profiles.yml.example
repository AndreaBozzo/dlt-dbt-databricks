# Copy to `profiles.yml` (gitignored, same dir) — values are read from environment variables,
# so you usually don't need to edit anything after copying. Populate the repo-root `.env` first.
#
# Auth shown here = Personal Access Token. For production prefer OAuth M2M (service principal):
# replace `token:` with `auth_type: oauth`, `client_id:`, `client_secret:`.
# See ../../docs/setup-databricks.md.

dlt_dbt_databricks:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      catalog: "{{ env_var('DATABRICKS_CATALOG', 'main') }}"
      schema: "{{ env_var('DATABRICKS_SCHEMA', 'analytics') }}"
      threads: 4

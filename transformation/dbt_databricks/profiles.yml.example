# Copy to `profiles.yml` (gitignored, same dir) and fill in host/http_path.
#
# Auth strategy:
#   LOCAL DEV  → auth_type: oauth   — reads ~/.databrickscfg (set up once with `databricks auth login`)
#                No PAT, no env vars, no browser popup after first login.
#   PRODUCTION → auth_type: oauth   + client_id / client_secret env vars (M2M service principal)
#
# See ../../docs/setup-databricks.md for workspace setup.

dlt_dbt_databricks:
  target: dev
  outputs:
    dev:
      type: databricks
      host: YOUR_HOST.cloud.databricks.com
      http_path: /sql/1.0/warehouses/YOUR_WAREHOUSE_ID
      auth_type: oauth                        # uses ~/.databrickscfg — run `databricks auth login` once
      catalog: workspace                      # your Unity Catalog managed catalog name
      schema: analytics                       # dbt builds models here
      threads: 4

    # --- Local/CI lane: DuckDB, no workspace needed ---
    # Reads the same file the dlt pipelines write when DLT_DESTINATION=duckdb.
    # Path is resolved from the process working dir — run from the repo root (make / CI do).
    duckdb:
      type: duckdb
      path: "{{ env_var('DUCKDB_PATH', 'local/dlt_dbt.duckdb') }}"
      schema: analytics
      threads: 4

    # --- Production: M2M OAuth (service principal) ---
    # prod:
    #   type: databricks
    #   host: YOUR_HOST.cloud.databricks.com
    #   http_path: /sql/1.0/warehouses/YOUR_WAREHOUSE_ID
    #   auth_type: oauth
    #   client_id: "{{ env_var('DATABRICKS_CLIENT_ID') }}"
    #   client_secret: "{{ env_var('DATABRICKS_CLIENT_SECRET') }}"
    #   catalog: workspace
    #   schema: analytics
    #   threads: 8

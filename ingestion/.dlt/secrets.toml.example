# Copy to `secrets.toml` (gitignored) and fill in, OR set the equivalent env vars in `.env`.
# Env-var form: DESTINATION__DATABRICKS__CREDENTIALS__<FIELD_IN_UPPERCASE>
# Docs: https://dlthub.com/docs/dlt-ecosystem/destinations/databricks

[destination.databricks.credentials]
server_hostname = "YOUR_HOST.cloud.databricks.com"         # no https://
http_path       = "/sql/1.0/warehouses/YOUR_WAREHOUSE_ID"  # Serverless Starter Warehouse
catalog         = "workspace"
access_token    = "dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX"      # replace with your PAT

# --- Production alternative: OAuth machine-to-machine (service principal) ---
# Remove access_token above and use:
# client_id     = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# client_secret = "doseXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Example SQL source (for sql_database_to_databricks.py) ---
# [sources.sql_database.credentials]
# drivername = "postgresql"
# database   = "dbname"
# username   = "user"
# password   = "pass"
# host       = "host"
# port       = 5432
